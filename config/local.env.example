# `xdd local dev init` creates config/local.env securely. This example documents
# its non-secret shape; keep every real Local environment file out of Git.
XDN_LOCAL_POSTGRES_PORT=5432
XDN_LOCAL_POSTGRES_ADMIN_PASSWORD=replace-with-a-random-local-admin-secret
XDN_GATEWAY_MIGRATOR_PASSWORD=replace-with-a-distinct-random-migrator-secret
XDN_GATEWAY_RUNTIME_PASSWORD=replace-with-a-distinct-random-runtime-secret
XDN_LOCAL_SEAWEEDFS_PORT=8333
XDN_LOCAL_TEMPORAL_PORT=7233
XDN_LOCAL_DBGATE_PORT=3000
XDN_LOCAL_GATEWAY_PORT=3001
XDN_GATEWAY_AUTH_SECRET=replace-with-a-random-local-auth-secret-at-least-32-characters
